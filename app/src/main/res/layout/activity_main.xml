<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorFondo"
    android:padding="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registro de articulos"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        />

    <!-- CAMPO QUE SOLO ACEPTA NUMEROS -->
    <EditText
        android:id="@+id/etCodigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Codigo del producto"
        android:inputType="number"
        android:background="@android:color/white"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        />

    <!-- CAMPO QUE ACEPTA ALFANUMERICOS, CAPITALIZADOS -->
    <EditText
        android:id="@+id/etDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descripcion (ej: Teclado mecanico)"
        android:inputType="textCapSentences"
        android:background="@android:color/white"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        />

    <!-- CAMPO DE PRECIO, ACEPTA NUMEROS Y DECIMALES -->
    <EditText
        android:id="@+id/etPrecio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Precio ($)"
        android:inputType="numberDecimal"
        android:background="@android:color/white"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        />

    <Button
        android:id="@+id/btnRegistrar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="GUARDAR ARTICULO"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="8dp"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBuscar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Buscar"
            android:layout_marginEnd="4dp"
            app:backgroundTint="#4CAF50"
            />

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editar"
            android:layout_marginEnd="4dp"
            app:backgroundTint="#FF9800"
            />

        <Button
            android:id="@+id/btnBorrar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Borrar"
            android:layout_marginEnd="4dp"
            app:backgroundTint="#F44336"
            />

    </LinearLayout>

</LinearLayout>